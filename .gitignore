# Secrets
.env
.env.local
*.key

# Data / runtime artifacts
clips/*
!clips/.gitkeep
output/*
!output/.gitkeep
cache/*
!cache/.gitkeep
work/
*.log

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environments. Use ./.venv only. The bin/lib/include/pyvenv.cfg entries
# guard against an accidental `python -m venv .` created at the repo root (which
# also overwrote this .gitignore once); safe here since the project has no such dirs.
.venv/
venv/
env/
bin/
lib/
lib64/
include/
share/
pyvenv.cfg

# OS
.DS_Store
